<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ToDoList" parent="Theme.MaterialComponents">
        <item name="colorPrimary">@color/brown_2</item>
        <item name="colorSecondary">@color/brown_1</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="ButtonStyle1" parent="Widget.Material3.Button">
        <item name="android:background">@color/brown_2</item>
    </style>

    <style name="ButtonStyle2" parent="Widget.Material3.Button">
        <item name="android:background">@color/dark_1</item>
    </style>

    <style name="ButtonStyle3" parent="Widget.Material3.Button">
        <item name="colorPrimary">@color/beige_2</item>
    </style>

    <style name="DeleteButton" parent="Widget.Material3.Button">
        <item name="android:background">#00000000</item>
        <item name="android:textColor">@color/dark_2</item>
    </style>

    <style name="TaskCardStyle">
        <item name="android:background">@color/brown_1</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="InputStyle">
        <item name="android:background">@color/off_white</item>
        <item name="android:textColor">@color/black</item>
    </style>
</resources>